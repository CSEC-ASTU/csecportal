generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                       String   @id @default(cuid())
  freeName                 String
  email                    String   @unique
  studentId                String?
  gmailId                  String?
  contact                  String?
  note                      String?
  expectedGenerationYear   String?
  discoveredDate           String?
  fieldOfStudy             String?
  unifiedById              String?
  passwordLink             String?
  statusDates              String?
  customerStatusLink       String?
  adminLink                String?
  personalStatusLink       String?
  shortListDescription     String?
  lastName                 String?
  firstAddress             String?
  alternateEmail           String?
  profileImage             String?
  githubProfile            String?
  supportHandle            String?
  successions              String?
  skillsJson               String?
  historyNotes             String?
  password                 String
  role                     String   @default("MEMBER")
  divisionId               String?
  isEmailVerified          Boolean  @default(false)
  status                   String   @default("ACTIVE")
  isRemovedFromDivision    Boolean  @default(false)
  removedFromDivisionAt    DateTime?
  removedFromDivisionBy    String?
  divisionRemovalReason    String?
  previousDivisionId       String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  division                 Division? @relation("DivisionMembers", fields: [divisionId], references: [id], onDelete: SetNull)
  headOfDivision           Division? @relation("DivisionHead")
  verificationTokens       VerificationToken[]
  passwordResetTokens      PasswordResetToken[]
  resources                Resource[] @relation("ResourceOwner")
  reminders                Reminder[]
  groupsCreated            Group[] @relation("GroupCreator")
  usersInGroups            UsersInGroups[]
  articlesAuthor           Article[] @relation("ArticleAuthor")
  comments                 Comment[] @relation("CommentUser")
  sessionsParticipant      SessionMembership[]
  attendanceMarked         Attendance[] @relation("AttendanceMarked")
  attendanceRecorded       Attendance[] @relation("AttendanceUser")
  electionsCreated         Election[] @relation("ElectionCreated")
  electionsWon             Election? @relation("ElectionWinner")
  nominationsAsNominee     Nomination[] @relation("NominationNominee")
  nominationsAsNominator   Nomination[] @relation("NominationNominator")
  votesAsVoter             Vote[] @relation("VoteVoter")
  votesAsCandidate         Vote[] @relation("VoteCandidate")
  electionHistories        ElectionHistory[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model OTP {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  purpose   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Division {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  headId      String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  head        User? @relation("DivisionHead", fields: [headId], references: [id], onDelete: SetNull)
  members     User[] @relation("DivisionMembers")
  resources   Resource[]
  groups      Group[]
  articles    Article[]
  sessions    Session[]
  elections   Election[]
}

model Resource {
  id          String   @id @default(cuid())
  name        String
  url         String
  type        String   @default("LINK")
  description String?
  divisionId  String?
  ownerId     String?
  createdAt   DateTime @default(now())

  division    Division? @relation(fields: [divisionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  owner       User? @relation("ResourceOwner", fields: [ownerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
}

model Reminder {
  id          String   @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime
  userId      String
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  divisionId  String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  division    Division       @relation(fields: [divisionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdBy   User           @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  users       UsersInGroups[]
}

model UsersInGroups {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  createdAt DateTime @default(now())
  isRemoved Boolean  @default(false)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, groupId])
}

model Article {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  divisionId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author    User     @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  division  Division? @relation(fields: [divisionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  comments  Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  articleId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation("CommentUser", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
}

model Session {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String
  divisionId  String
  createdAt   DateTime @default(now())

  division    Division            @relation(fields: [divisionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  memberships SessionMembership[]
  attendances Attendance[]
}

model SessionMembership {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
}

model Attendance {
  id        String   @id @default(cuid())
  memberId  String
  date      DateTime
  status    String
  markedById String
  sessionId String
  createdAt DateTime @default(now())

  member    User     @relation("AttendanceUser", fields: [memberId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  markedBy  User     @relation("AttendanceMarked", fields: [markedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
}

model Election {
  id                 String   @id @default(cuid())
  title              String
  description        String?
  status             String   @default("DRAFT")
  divisionId         String
  createdById        String
  nominationStart    DateTime
  nominationEnd      DateTime
  votingStart        DateTime
  votingEnd          DateTime
  resultsDate        DateTime?
  minSeniority       Int?     @default(1)
  allowSelfNominate  Boolean  @default(true)
  eligibleRoleIdsJson String?
  winnerId           String?  @unique
  voteCount          Int?     @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  division           Division             @relation(fields: [divisionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdBy          User                 @relation("ElectionCreated", fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  winner             User?                @relation("ElectionWinner", fields: [winnerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  nominations        Nomination[]
  votes              Vote[]
  histories          ElectionHistory[]
}

model Nomination {
  id            String   @id @default(cuid())
  electionId    String
  nomineeId     String
  nominatedById String
  position      String
  status        String   @default("PENDING")
  reason        String?
  rejectionNote String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  election      Election @relation(fields: [electionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  nominee       User     @relation("NominationNominee", fields: [nomineeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  nominatedBy   User     @relation("NominationNominator", fields: [nominatedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
}

model Vote {
  id          String   @id @default(cuid())
  electionId  String
  voterId     String
  candidateId String
  createdAt   DateTime @default(now())

  election    Election @relation(fields: [electionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  voter       User     @relation("VoteVoter", fields: [voterId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  candidate   User     @relation("VoteCandidate", fields: [candidateId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([electionId, voterId])
}

model ElectionHistory {
  id        String   @id @default(cuid())
  electionId String
  action    String
  details   String?
  changedById String
  createdAt DateTime @default(now())

  election  Election @relation(fields: [electionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  changedBy User     @relation(fields: [changedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  location    String
  date        DateTime
  status      String   @default("PRIVATE")
  createdAt   DateTime @default(now())
}

model smtp_config {
  id        String   @id @default(cuid())
  user      String
  key       String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  createdAt DateTime @default(now())
}

model Rule {
  id          String   @id @default(cuid())
  title       String
  description String
  createdAt   DateTime @default(now())
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String
  description String
  createdAt   DateTime @default(now())
}
